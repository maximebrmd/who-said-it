# Supabase project (public anon access — read-only via RLS).
# Copy to .env.local and fill in. Without these the app falls back to the
# committed synthetic sample data so it still runs.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# The data loader (scripts/load-chats.ts) does NOT use a .env value: it shells
# out to supabase-axi, which reads SUPABASE_ACCESS_TOKEN from the environment.
# Export it in your shell instead (NEVER commit a real value). See the README.
#   export SUPABASE_ACCESS_TOKEN="$(cat ~/.who-said-it-supabase-token)"

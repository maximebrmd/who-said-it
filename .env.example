# Supabase project (public anon access — read-only via RLS).
# Copy to .env.local and fill in. Without these the app falls back to the
# committed synthetic sample data so it still runs.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Only needed locally to run scripts/load-chats.ts (NEVER commit a real value).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
